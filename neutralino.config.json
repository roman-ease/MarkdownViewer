{
  "$schema": "https://raw.githubusercontent.com/neutralinojs/neutralinojs/main/schemas/neutralino.config.schema.json",
  "applicationId": "dev.markdown.viewer",
  "version": "1.6.3",
  "defaultMode": "window",
  "port": 0,
  "documentRoot": "/resources/",
  "url": "/",
  "enableServer": true,
  "enableNativeAPI": true,
  "tokenSecurity": "one-time",
  "logging": {
    "enabled": true,
    "writeToLogFile": true
  },
  "nativeAllowList": [
    "app.exit",
    "os.showMessageBox",
    "os.showOpenDialog",
    "os.showSaveDialog",
    "os.getEnv",
    "os.execCommand",
    "os.showNotification",
    "filesystem.readFile",
    "filesystem.writeFile",
    "filesystem.getStats",
    "filesystem.readBinaryFile",
    "filesystem.createDirectory",
    "filesystem.writeBinaryFile",
    "storage.setData",
    "storage.getData",
    "window.show",
    "window.hide",
    "window.focus",
    "window.setTitle",
    "debug.log"
  ],
  "modes": {
    "window": {
      "title": "Markdown Viewer",
      "width": 1200,
      "height": 800,
      "minWidth": 600,
      "minHeight": 400,
      "center": true,
      "fullScreen": false,
      "alwaysOnTop": false,
      "icon": "/resources/icons/appIcon.png",
      "enableInspector": false,
      "borderless": false,
      "maximize": false,
      "hidden": true,
      "resizable": true,
      "exitProcessOnClose": false
    }
  },
  "cli": {
    "binaryName": "MarkdownViewer",
    "resourcesPath": "/resources/",
    "extensionsPath": "/extensions/",
    "clientLibrary": "/resources/js/neutralino.js",
    "binaryVersion": "6.5.0",
    "clientVersion": "6.5.0"
  }
}